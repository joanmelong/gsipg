---
import Breadcrumb from '../ui/Breadcrumb.astro';
import ArticleCard from '../ui/ArticleCard.astro';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import SocialShare from '../ui/SocialShare.astro';
import {
  formatArticleDate,
  getRelatedArticles,
  type Article,
} from '../../data/articles';
import { siteConfig } from '../../config/site';

interface Props {
  article: Article;
}

const { article } = Astro.props;
const related = getRelatedArticles(article.slug);
const articleUrl = new URL(`/actualites/${article.slug}`, siteConfig.url).href;

const breadcrumbItems = [
  { label: 'Accueil', href: '/' },
  { label: 'Actualités', href: '/actualites' },
  { label: article.title, href: `/actualites/${article.slug}` },
];
---

<article class="bg-white">
  <div class="relative h-[40vh] min-h-[280px] max-h-[480px] overflow-hidden sm:h-[45vh]">
    <img
      src={article.image}
      alt={article.imageAlt}
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      width="1200"
      height="630"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-secondary/90 via-secondary/40 to-transparent"
      aria-hidden="true"
    ></div>
    <Container class="absolute inset-x-0 bottom-0 pb-8 pt-16 sm:pb-12">
      <Breadcrumb items={breadcrumbItems} class="mb-4 text-white/80 [&_a]:text-white/90 [&_a:hover]:text-white" />
      <span class="inline-block rounded-full bg-primary/90 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-neutral-dark">
        {article.category}
      </span>
      <h1 class="mt-3 font-subheading text-2xl font-bold normal-case leading-tight text-white sm:text-3xl lg:text-4xl">
        {article.title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-white/90">
        <time datetime={article.date}>{formatArticleDate(article.date)}</time>
        <span aria-hidden="true">·</span>
        <span>{article.author}</span>
      </div>
    </Container>
  </div>

  <Container class="py-10 sm:py-14">
    <div class="mx-auto max-w-3xl">
      <p class="text-lg font-medium leading-relaxed text-secondary">{article.excerpt}</p>

      <div class="mt-8 space-y-5 text-base leading-relaxed text-neutral-text">
        {article.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <div class="mt-10 border-t border-border pt-8">
        <SocialShare url={articleUrl} title={article.title} />
      </div>
    </div>
  </Container>
</article>

{
  related.length > 0 && (
    <Section background="neutral" ariaLabel="Articles connexes">
      <Container>
        <h2 class="text-center">Articles connexes</h2>
        <ul class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
          {related.map((item) => (
            <li>
              <ArticleCard article={item} />
            </li>
          ))}
        </ul>
        <div class="mt-10 text-center">
          <a
            href="/actualites"
            class="text-sm font-semibold text-secondary underline-offset-2 hover:underline"
          >
            ← Retour aux actualités
          </a>
        </div>
      </Container>
    </Section>
  )
}
