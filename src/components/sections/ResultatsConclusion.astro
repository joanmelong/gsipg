---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import { resultsConclusion } from '../../data/results';
---

<Section ariaLabel="Bilan de l'année">
  <Container>
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-14 xl:gap-20">
      <div class="overflow-hidden rounded-2xl shadow-md ring-1 ring-border/60">
        <img
          src={resultsConclusion.image.src}
          alt={resultsConclusion.image.alt}
          class="aspect-[4/3] h-full w-full object-cover object-center lg:aspect-auto lg:min-h-[340px]"
          loading="lazy"
          width="800"
          height="600"
        />
      </div>

      <div class="flex flex-col gap-5 lg:gap-6">
        <h2 class="font-subheading text-2xl font-bold normal-case tracking-normal text-secondary sm:text-3xl lg:text-4xl">
          {resultsConclusion.title}
        </h2>

        <p class="text-sm leading-relaxed text-neutral-text sm:text-base">
          {resultsConclusion.text}
        </p>

        <div class="pt-2">
          <Button href={resultsConclusion.button.href}>{resultsConclusion.button.label}</Button>
        </div>
      </div>
    </div>
  </Container>
</Section>
