---
import Container from '../ui/Container.astro';
import BlurText from '../react/BlurText';
import FadeIn from '../react/FadeIn';
import { vieScolaireHero } from '../../data/vie-scolaire';
---

<section class="relative overflow-hidden bg-secondary pt-8 sm:pt-10 lg:pt-12" aria-label="Introduction vie scolaire">
  <!-- Motif de fond -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.08]"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 24px 24px;"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.05]"
    style="background: repeating-linear-gradient(135deg, transparent, transparent 48px, #ffffff 48px, #ffffff 49px);"
    aria-hidden="true"
  ></div>

  <Container class="relative pt-0 pb-16 sm:pb-20 lg:pb-24">
    <div class="grid grid-cols-1 items-center gap-6 lg:grid-cols-2 lg:gap-10">
      <!-- Texte -->
      <div class="max-w-xl">
        <FadeIn client:visible>
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-primary">
            {vieScolaireHero.tag}
          </p>
        </FadeIn>

        <BlurText
          client:visible
          text={vieScolaireHero.title}
          as="h1"
          className="mt-4 font-subheading text-3xl font-bold normal-case leading-tight tracking-normal text-white sm:text-4xl lg:text-[2.75rem]"
        />

        <FadeIn client:visible delay={200} className="mt-5 text-sm leading-relaxed text-white/85 sm:text-base">
          <p>{vieScolaireHero.subtitle}</p>
        </FadeIn>
      </div>

      <!-- Visuel droit -->
      <div class="relative mx-auto w-full max-w-md lg:max-w-none lg:justify-self-end">
        <div class="absolute -left-4 top-8 h-32 w-24 rotate-[-12deg] rounded-3xl bg-primary/30 sm:h-40 sm:w-28" aria-hidden="true"></div>
        <div class="absolute right-4 top-0 h-28 w-20 rotate-12 rounded-3xl bg-primary/20 sm:h-36 sm:w-24" aria-hidden="true"></div>
        <div class="absolute bottom-12 left-0 h-20 w-16 rotate-6 rounded-2xl bg-accent-orange/25" aria-hidden="true"></div>

        <span class="absolute right-8 top-4 text-2xl text-primary/60" aria-hidden="true">+</span>
        <span class="absolute bottom-24 left-8 h-3 w-3 rounded-full border-2 border-primary/50" aria-hidden="true"></span>

        <div class="relative z-10 flex justify-center">
          <img
            src={vieScolaireHero.portrait.src}
            alt={vieScolaireHero.portrait.alt}
            class="max-h-[280px] w-auto object-contain object-bottom drop-shadow-2xl sm:max-h-[320px] lg:max-h-[360px]"
            loading="eager"
            fetchpriority="high"
            width="700"
            height="900"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- 4 cartes chevauchant le hero et la section suivante -->
<div class="relative z-30 -mt-16 sm:-mt-20 lg:-mt-24">
  <Container>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-4">
      {
        vieScolaireHero.navCards.map((card) => (
          <a
            href={`#${card.id}`}
            class="group flex flex-col rounded-2xl bg-white p-6 shadow-[0_16px_40px_rgba(0,0,0,0.12)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_48px_rgba(46,117,182,0.18)]"
          >
            <span
              class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-secondary shadow-md"
              aria-hidden="true"
            >
              <img
                src={card.iconSrc}
                alt=""
                class="h-8 w-8 object-contain"
                width="32"
                height="32"
              />
            </span>

            <h2 class="mt-5 font-subheading text-lg font-bold normal-case tracking-normal text-secondary">
              {card.title}
            </h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-text">{card.description}</p>
          </a>
        ))
      }
    </div>
  </Container>
</div>
