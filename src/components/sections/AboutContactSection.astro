---
import Container from '../ui/Container.astro';
import { aboutContact } from '../../data/about';
---

<section class="py-10 sm:py-14 lg:py-16" aria-labelledby="contact-title">
  <Container>
    <div class="overflow-hidden rounded-[2.5rem] bg-secondary shadow-[0_24px_60px_rgba(46,117,182,0.25)]">
      <div class="grid grid-cols-1 lg:grid-cols-2 lg:items-stretch">
        <div class="px-6 py-10 sm:px-10 sm:py-12 lg:px-12">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Restons en contact</p>
          <h2
            id="contact-title"
            class="mt-3 font-subheading text-3xl font-bold normal-case leading-tight tracking-normal text-white sm:text-4xl"
          >
            {aboutContact.title}
          </h2>
          <p class="mt-3 text-sm text-white/85 sm:text-base">{aboutContact.subtitle}</p>

          <ul class="mt-8 space-y-5">
            {
              aboutContact.phones.map((phone) => (
                <li>
                  <a
                    href={phone.href}
                    class="group flex items-start gap-4 rounded-2xl bg-white/10 px-4 py-3 transition hover:bg-white/15"
                  >
                    <span
                      class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/15 text-primary"
                      aria-hidden="true"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"></path>
                      </svg>
                    </span>
                    <span>
                      <span class="block text-xs uppercase tracking-wide text-white/70">{phone.label}</span>
                      <span class="mt-0.5 block font-subheading text-base font-semibold text-white group-hover:text-primary">
                        {phone.display}
                      </span>
                    </span>
                  </a>
                </li>
              ))
            }

            <li>
              <a
                href={aboutContact.email.href}
                class="group flex items-start gap-4 rounded-2xl bg-white/10 px-4 py-3 transition hover:bg-white/15"
              >
                <span
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/15 text-primary"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"></path>
                  </svg>
                </span>
                <span>
                  <span class="block text-xs uppercase tracking-wide text-white/70">Email</span>
                  <span class="mt-0.5 block font-subheading text-base font-semibold text-white group-hover:text-primary">
                    {aboutContact.email.display}
                  </span>
                </span>
              </a>
            </li>
          </ul>

          <div class="mt-8 rounded-2xl border border-white/20 bg-white/10 px-5 py-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-primary">Heures d&apos;ouverture</p>
            <ul class="mt-3 space-y-2">
              {
                aboutContact.hours.map((slot) => (
                  <li class="flex flex-wrap items-baseline justify-between gap-2 text-sm text-white/90">
                    <span>{slot.days}</span>
                    <span class="font-semibold text-white">{slot.time}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <a
            href={aboutContact.mapsDirectionsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary transition hover:text-white"
          >
            {aboutContact.address}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25"></path>
            </svg>
          </a>
        </div>

        <div class="relative aspect-[4/3] w-full sm:aspect-[16/10] lg:aspect-auto lg:min-h-[520px]">
          <a
            href={aboutContact.mapsDirectionsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group absolute inset-0 block overflow-hidden"
            aria-label={`Ouvrir l'itinéraire vers ${aboutContact.address} dans Google Maps`}
          >
            <iframe
              title={`Carte — ${aboutContact.address}`}
              src={aboutContact.mapsEmbedUrl}
              class="h-full w-full border-0 grayscale-[20%] transition duration-300 group-hover:grayscale-0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>

            <span
              class="pointer-events-none absolute inset-x-0 bottom-0 flex justify-center bg-gradient-to-t from-secondary/90 via-secondary/40 to-transparent p-4 sm:p-6 lg:opacity-0 lg:transition lg:group-hover:opacity-100"
            >
              <span class="rounded-full bg-white px-4 py-2 text-xs font-semibold text-secondary shadow-lg sm:px-5 sm:text-sm">
                Ouvrir dans Google Maps
              </span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
