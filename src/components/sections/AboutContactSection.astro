---
import Container from '../ui/Container.astro';
import { aboutContact } from '../../data/about';

const inputClasses =
  'w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-neutral-dark placeholder:text-neutral-text/60 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-secondary';

const cardClasses =
  'group flex items-center gap-4 rounded-2xl bg-white px-5 py-6 shadow-[0_16px_40px_rgba(0,0,0,0.12)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_48px_rgba(46,117,182,0.18)] sm:px-6';

const iconBoxClasses =
  'flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-secondary shadow-md';
---

<section class="bg-neutral-bg py-12 sm:py-16 lg:py-20" aria-labelledby="contact-title">
  <Container>
    <div class="mx-auto max-w-3xl text-center">
      <p
        class="inline-flex rounded-full border border-secondary/25 bg-white px-5 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-secondary"
      >
        {aboutContact.badge}
      </p>
      <h2
        id="contact-title"
        class="mt-5 font-subheading text-2xl font-bold normal-case leading-tight tracking-normal text-neutral-dark sm:text-3xl lg:text-4xl"
      >
        {aboutContact.title}
      </h2>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-5 sm:mt-12 md:grid-cols-3 md:gap-5">
      <article class={cardClasses}>
        <span class={iconBoxClasses} aria-hidden="true">
          <img
            src={aboutContact.email.iconSrc}
            alt=""
            class="h-8 w-8 object-contain"
            width="32"
            height="32"
            loading="lazy"
          />
        </span>
        <div class="min-w-0 text-left">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-text">{aboutContact.email.label}</p>
          <a
            href={aboutContact.email.href}
            class="mt-1 block truncate font-subheading text-sm font-semibold text-neutral-dark transition hover:text-secondary sm:text-base"
          >
            {aboutContact.email.display}
          </a>
        </div>
      </article>

      <article class={cardClasses}>
        <span class={iconBoxClasses} aria-hidden="true">
          <img
            src={aboutContact.phoneIconSrc}
            alt=""
            class="h-8 w-8 object-contain"
            width="32"
            height="32"
            loading="lazy"
          />
        </span>
        <div class="min-w-0 text-left">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-text">{aboutContact.phoneLabel}</p>
          <div class="mt-1 space-y-0.5">
            {
              aboutContact.phones.map((phone) => (
                <a
                  href={phone.href}
                  class="block font-subheading text-sm font-semibold text-neutral-dark transition hover:text-secondary sm:text-base"
                >
                  {phone.display}
                </a>
              ))
            }
          </div>
        </div>
      </article>

      <article class={cardClasses}>
        <span class={iconBoxClasses} aria-hidden="true">
          <img
            src={aboutContact.officeIconSrc}
            alt=""
            class="h-8 w-8 object-contain"
            width="32"
            height="32"
            loading="lazy"
          />
        </span>
        <div class="min-w-0 text-left">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-text">{aboutContact.officeLabel}</p>
          <a
            href={aboutContact.mapsDirectionsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 block font-subheading text-sm font-semibold leading-snug text-neutral-dark transition hover:text-secondary sm:text-base"
          >
            {aboutContact.address}
          </a>
          <ul class="mt-2 space-y-0.5 text-xs text-neutral-text">
            {
              aboutContact.hours.map((slot) => (
                <li>
                  {slot.days} : <span class="font-semibold text-neutral-dark">{slot.time}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </article>
    </div>

    <div
      id="contact"
      class="scroll-mt-28 mt-10 overflow-hidden rounded-[2rem] bg-white p-5 shadow-[0_16px_50px_rgba(46,117,182,0.12)] sm:mt-12 sm:p-8 lg:p-10"
    >
      <div class="grid grid-cols-1 items-stretch gap-8 lg:grid-cols-2 lg:gap-10">
        <div class="relative min-h-[280px] overflow-hidden rounded-2xl bg-neutral-bg sm:min-h-[340px] lg:min-h-[420px]">
          <iframe
            title={`Carte — ${aboutContact.address}`}
            src={aboutContact.mapsEmbedUrl}
            class="absolute inset-0 h-full w-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>

        <form
          id="about-contact-form"
          class="flex flex-col justify-center gap-5"
          aria-label="Formulaire de contact"
          data-contact-email={aboutContact.email.display}
          novalidate
        >
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="contact-first-name" class="mb-2 block text-sm font-medium text-neutral-dark">
                {aboutContact.form.firstNameLabel}
              </label>
              <input
                id="contact-first-name"
                name="firstName"
                type="text"
                autocomplete="given-name"
                required
                class={inputClasses}
              />
            </div>
            <div>
              <label for="contact-last-name" class="mb-2 block text-sm font-medium text-neutral-dark">
                {aboutContact.form.lastNameLabel}
              </label>
              <input
                id="contact-last-name"
                name="lastName"
                type="text"
                autocomplete="family-name"
                required
                class={inputClasses}
              />
            </div>
          </div>

          <div>
            <label for="contact-message" class="mb-2 block text-sm font-medium text-neutral-dark">
              {aboutContact.form.messageLabel}
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="6"
              required
              placeholder={aboutContact.form.messagePlaceholder}
              class={`${inputClasses} min-h-[160px] resize-y`}
            ></textarea>
          </div>

          <button
            type="submit"
            class="mt-1 w-full rounded-full bg-secondary px-8 py-3.5 text-sm font-semibold text-white transition hover:bg-secondary/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary"
          >
            {aboutContact.form.submitLabel}
          </button>
        </form>
      </div>
    </div>
  </Container>
</section>

<script>
  function setupContactForm() {
    const form = document.getElementById('about-contact-form');
    if (!form || form.dataset.bound === 'true') return;

    form.dataset.bound = 'true';
    const email = form.dataset.contactEmail ?? '';

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const data = new FormData(form);
      const firstName = String(data.get('firstName') ?? '').trim();
      const lastName = String(data.get('lastName') ?? '').trim();
      const message = String(data.get('message') ?? '').trim();

      if (!firstName || !lastName || !message) {
        form.reportValidity();
        return;
      }

      const subject = encodeURIComponent(`Contact GSIPG — ${firstName} ${lastName}`);
      const body = encodeURIComponent(
        `Prénom : ${firstName}\nNom : ${lastName}\n\nMessage :\n${message}`,
      );

      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    });
  }

  function scrollToContactHash() {
    if (window.location.hash !== '#contact') return;
    const target = document.getElementById('contact');
    target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  setupContactForm();
  scrollToContactHash();
  document.addEventListener('astro:page-load', () => {
    setupContactForm();
    scrollToContactHash();
  });
</script>
