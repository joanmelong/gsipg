---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import ArticleCard from '../ui/ArticleCard.astro';
import Button from '../ui/Button.astro';
import { getSortedArticles } from '../../data/articles';

const latestArticles = getSortedArticles().slice(0, 3);
---

<Section background="neutral" ariaLabel="Dernières actualités">
  <Container>
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <h2>Dernières actualités</h2>
        <p class="mt-2 max-w-xl text-neutral-text">
          La vie de l'école en images et en nouvelles : projets, événements et réussites de nos élèves.
        </p>
      </div>
      <Button href="/actualites" variant="secondary" size="sm">
        Toutes les actualités
      </Button>
    </div>

    <ul class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
      {
        latestArticles.map((article) => (
          <li>
            <ArticleCard article={article} />
          </li>
        ))
      }
    </ul>
  </Container>
</Section>
