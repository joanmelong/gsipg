---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Restez informé',
  description = 'Recevez nos actualités, événements et conseils pédagogiques directement dans votre boîte mail.',
} = Astro.props;
---

<section class="bg-neutral-bg py-16 sm:py-20" aria-label="Inscription newsletter">
  <Container>
    <div class="mx-auto max-w-xl text-center">
      <h2>{title}</h2>
      <p class="mt-4 text-neutral-text">{description}</p>
      <form id="home-newsletter-form" class="mt-8 flex flex-col gap-3 sm:flex-row" aria-label="Inscription newsletter" novalidate>
        <label for="home-newsletter-email" class="sr-only">Adresse email</label>
        <input
          id="home-newsletter-email"
          type="email"
          name="email"
          placeholder="votre@email.com"
          required
          class="flex-1 rounded-lg border border-border bg-white px-4 py-3 text-neutral-dark placeholder:text-neutral-text/60 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-secondary"
        />
        <Button type="submit" size="md">S'abonner</Button>
      </form>
      <p id="home-newsletter-feedback" class="mt-3 hidden text-sm text-accent-green" role="status"></p>
      <p class="mt-3 text-xs text-neutral-text">
        En vous inscrivant, vous acceptez notre{' '}
        <a href="/confidentialite" class="text-secondary underline hover:text-primary">
          politique de confidentialité
        </a>.
      </p>
    </div>
  </Container>
</section>

<script>
  function setupHomeNewsletter() {
    const form = document.getElementById('home-newsletter-form');
    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    const feedback = document.getElementById('home-newsletter-feedback');

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const input = form.querySelector<HTMLInputElement>('[name="email"]');
      if (!input?.checkValidity()) {
        input?.reportValidity();
        return;
      }
      if (feedback) {
        feedback.textContent = 'Merci pour votre inscription !';
        feedback.classList.remove('hidden');
      }
      form.reset();
    });
  }

  setupHomeNewsletter();
  document.addEventListener('astro:page-load', setupHomeNewsletter);
</script>
