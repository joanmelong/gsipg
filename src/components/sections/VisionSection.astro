---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { visionContent } from '../../data/home';

const [photoTop, photoBottom] = visionContent.photos;
const [statTop, statBottom] = visionContent.stats;
---

<section class="relative overflow-hidden bg-white py-16 sm:py-20 lg:py-24" aria-label="Notre vision pédagogique">
  <!-- Motif points à droite -->
  <div
    class="pointer-events-none absolute inset-y-0 right-0 w-1/3 opacity-[0.35]"
    style="background-image: radial-gradient(circle, #71d7f7 1.5px, transparent 1.5px); background-size: 22px 22px;"
    aria-hidden="true"
  ></div>

  <Container>
    <div class="relative grid grid-cols-1 items-center gap-14 lg:grid-cols-2 lg:gap-16 xl:gap-24">
      <!-- Colonne gauche : montage photos -->
      <div class="relative mx-auto w-full max-w-lg lg:max-w-none">
        <div class="relative min-h-[420px] sm:min-h-[480px]">
          <!-- Photo haut gauche -->
          <div
            class="absolute left-0 top-0 z-10 w-[58%] overflow-hidden rounded-[1.75rem] shadow-lg sm:w-[55%]"
            style={`background-color: ${photoTop.bg}`}
          >
            <div class="flex aspect-[3/4] items-end justify-center px-4 pt-6 pb-0">
              <img
                src={photoTop.src}
                alt={photoTop.alt}
                class="h-[88%] w-full object-cover object-top"
                loading="lazy"
                width="320"
                height="400"
              />
            </div>
          </div>

          <!-- Photo bas droite -->
          <div
            class="absolute bottom-0 right-0 z-20 w-[58%] overflow-hidden rounded-[1.75rem] shadow-xl sm:w-[55%]"
            style={`background-color: ${photoBottom.bg}`}
          >
            <div class="flex aspect-[3/4] items-end justify-center px-4 pt-6 pb-0">
              <img
                src={photoBottom.src}
                alt={photoBottom.alt}
                class="h-[88%] w-full object-cover object-top"
                loading="lazy"
                width="320"
                height="400"
              />
            </div>
          </div>

          <!-- Badge stat haut -->
          <div class="absolute right-[8%] top-[18%] z-30 flex items-center gap-3 rounded-2xl border border-border/60 bg-white px-4 py-3 shadow-md sm:right-[12%]">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary/10 text-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"></path>
              </svg>
            </span>
            <div>
              <span class="block text-lg font-bold leading-none text-neutral-dark">{statTop.value}</span>
              <span class="text-xs text-neutral-text">{statTop.label}</span>
            </div>
          </div>

          <!-- Badge stat bas -->
          <div class="absolute bottom-[8%] left-[4%] z-30 rounded-2xl border border-border/60 bg-white px-5 py-3 shadow-md sm:left-[8%]">
            <span class="block text-xl font-bold text-neutral-dark">{statBottom.value}</span>
            <span class="text-xs text-neutral-text">{statBottom.label}</span>
          </div>

          <!-- Flèche décorative -->
          <svg
            class="absolute left-[42%] top-[42%] z-[5] h-16 w-16 text-primary/60 sm:h-20 sm:w-20"
            viewBox="0 0 80 80"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M8 12 C 28 8, 38 28, 52 38 S 72 58, 68 72"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-dasharray="4 6"
            ></path>
            <path d="M60 68 L68 72 L64 62" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </div>
      </div>

      <!-- Colonne droite : texte -->
      <div>
        <p class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 text-primary" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM9.555 7.168A1 1 0 0 0 8 8v4a1 1 0 0 0 1.555.832l3-2a1 1 0 0 0 0-1.664l-3-2Z" clip-rule="evenodd"></path>
          </svg>
          {visionContent.tag}
        </p>

        <h2 class="mt-5 font-subheading text-3xl font-bold normal-case leading-tight tracking-normal text-neutral-dark sm:text-4xl lg:text-[2.65rem]">
          {visionContent.title}
          <em class="not-italic text-secondary underline decoration-primary decoration-wavy decoration-2 underline-offset-4">
            {visionContent.titleHighlight}
          </em>
        </h2>

        <p class="mt-6 max-w-xl leading-relaxed text-neutral-text">
          {visionContent.intro}
        </p>

        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {
            visionContent.pillars.map((pillar, index) => (
              <div class="flex gap-3">
                <span
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary/20 text-secondary"
                  aria-hidden="true"
                >
                  {index === 0 ? (
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802"></path>
                    </svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z"></path>
                    </svg>
                  )}
                </span>
                <div>
                  <h3 class="font-subheading text-base font-semibold normal-case tracking-normal text-neutral-dark">{pillar.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-neutral-text">{pillar.description}</p>
                </div>
              </div>
            ))
          }
        </div>

        <div class="mt-10">
          <Button
            href={visionContent.cta.href}
            size="lg"
            class="gap-2 rounded-full !bg-secondary px-8 normal-case tracking-normal hover:!bg-secondary/90"
          >
            {visionContent.cta.label}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25"></path>
            </svg>
          </Button>
        </div>
      </div>
    </div>
  </Container>
</section>
