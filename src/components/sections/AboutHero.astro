---
import Container from '../ui/Container.astro';
import { aboutHero } from '../../data/about';
---

<section
  class="relative flex min-h-[50vh] items-center overflow-hidden sm:min-h-[55vh] lg:min-h-[60vh]"
  aria-label="Introduction"
>
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src={aboutHero.background.src}
      alt=""
      class="h-full w-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1080"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to right, rgb(46 117 182 / 0.95) 0%, rgb(46 117 182 / 0.88) 22%, rgb(46 117 182 / 0.65) 45%, rgb(46 117 182 / 0.35) 65%, rgb(46 117 182 / 0.15) 80%, transparent 92%);"
    ></div>
  </div>

  <Container class="relative z-10 py-12 sm:py-16 lg:py-20">
    <div class="max-w-xl pl-2 sm:pl-4 md:max-w-2xl">
      <h1
        class="font-subheading text-3xl font-bold normal-case leading-tight tracking-normal text-white drop-shadow-md sm:text-4xl lg:text-[2.75rem]"
      >
        {aboutHero.title}
      </h1>
      <p class="mt-5 max-w-lg text-base leading-relaxed text-white/90 sm:text-lg">
        {aboutHero.subtitle}
      </p>
    </div>
  </Container>
</section>
