---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { formatPageTitle, siteConfig } from '../config/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
  elevatedHeader?: boolean;
}

const { title, description, ogImage = '/images/logo.svg', noIndex = false, elevatedHeader = false } = Astro.props;

const pageTitle = formatPageTitle(title);
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'School',
  name: siteConfig.name,
  alternateName: siteConfig.shortName,
  url: siteConfig.url,
  description: siteConfig.description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Yaoundé',
    addressCountry: 'CM',
  },
  telephone: siteConfig.contact.phone,
  email: siteConfig.contact.email,
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@600;700&family=Poppins:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteConfig.url).href} />
    <meta property="og:locale" content="fr_CM" />
    <meta property="og:site_name" content={siteConfig.shortName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteConfig.url).href} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="sr-only sr-only-focusable">Aller au contenu</a>
    <Header elevated={elevatedHeader} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
