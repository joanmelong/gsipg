---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import Button from '../../components/ui/Button.astro';
import { resultsIntro, stats, examResults, conclusion } from '../../data/results';
---

<BaseLayout
  title="Résultats Scolaires"
  description="Découvrez les performances et taux de réussite des élèves du GSIPG aux examens nationaux."
>
  <Section background="neutral" ariaLabel="Introduction">
    <Container>
      <PageHeader title="Nos Résultats" subtitle={resultsIntro} />
    </Container>
  </Section>

  <Section ariaLabel="Statistiques clés">
    <Container>
      <h2 class="text-center">Performances en chiffres</h2>
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          stats.map((stat) => (
            <div class="rounded-xl bg-neutral-bg p-6 text-center">
              <p class="font-display text-4xl text-secondary md:text-5xl">{stat.value}</p>
              <h3 class="mt-2 text-base">{stat.label}</h3>
              <p class="mt-1 text-sm text-neutral-text">{stat.detail}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </Section>

  <Section background="neutral" ariaLabel="Résultats aux examens">
    <Container>
      <h2 class="text-center">Résultats aux examens nationaux</h2>
      <div class="mt-10 overflow-x-auto">
        <table class="w-full min-w-[480px] border-collapse text-left">
          <thead>
            <tr class="border-b-2 border-secondary bg-white">
              <th class="px-4 py-3 font-semibold text-secondary" scope="col">Niveau</th>
              <th class="px-4 py-3 font-semibold text-secondary" scope="col">Admis</th>
              <th class="px-4 py-3 font-semibold text-secondary" scope="col">Présentés</th>
              <th class="px-4 py-3 font-semibold text-secondary" scope="col">Taux</th>
            </tr>
          </thead>
          <tbody>
            {
              examResults.map((row) => (
                <tr class="border-b border-border bg-white">
                  <td class="px-4 py-3">{row.level}</td>
                  <td class="px-4 py-3">{row.admitted}</td>
                  <td class="px-4 py-3">{row.total}</td>
                  <td class="px-4 py-3 font-semibold text-accent-green">{row.rate}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </Container>
  </Section>

  <Section ariaLabel="Conclusion">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <h2>Bilan de l'année</h2>
        <p class="mt-4 text-neutral-text">{conclusion}</p>
        <div class="mt-8">
          <Button href="/admissions">Inscrire mon enfant</Button>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
